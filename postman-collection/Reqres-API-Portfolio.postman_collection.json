{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Reqres.in — API Portfolio",
		"description": "QA portfolio collection for https://reqres.in — list, read, create, update, and delete user flows with automated status, timing, and JSON assertions.\n\n**Authentication:** Reqres requires header `x-api-key`. Create a free key at https://app.reqres.in/api-keys and set the collection variable `apiKey` (Current Value).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "key",
				"value": "x-api-key",
				"type": "string"
			},
			{
				"key": "value",
				"value": "{{apiKey}}",
				"type": "string"
			},
			{
				"key": "in",
				"value": "header",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"const key = pm.collectionVariables.get('apiKey');",
					"if (!key || String(key).trim() === '') {",
					"    console.warn('[Reqres] Set collection variable `apiKey` (free: https://app.reqres.in/api-keys).');",
					"}"
				],
				"type": "text/javascript"
			}
		}
	],
	"item": [
		{
			"name": "Users",
			"item": [
				{
					"name": "GET List users",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const MAX_MS = 3000;",
									"",
									"pm.test('[GET-LIST] Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('[GET-LIST] Response time is within budget', function () {",
									"    pm.expect(pm.response.responseTime, 'responseTime ms').to.be.below(MAX_MS);",
									"});",
									"",
									"pm.test('[GET-LIST] Response body is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('[GET-LIST] Response has pagination and data array', function () {",
									"    const body = pm.response.json();",
									"    pm.expect(body).to.have.keys('page', 'per_page', 'total', 'total_pages', 'data');",
									"    pm.expect(body.data).to.be.an('array').that.is.not.empty;",
									"});",
									"",
									"pm.test('[GET-LIST] User object has required fields', function () {",
									"    const first = pm.response.json().data[0];",
									"    pm.expect(first).to.include.keys('id', 'email', 'first_name', 'last_name', 'avatar');",
									"    pm.expect(first.id).to.be.a('number');",
									"    pm.expect(first.email).to.be.a('string').and.to.match(/@/);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users?page=1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								}
							]
						},
						"description": "Paginated list of users. Validates 200, JSON, pagination fields, and first user shape."
					},
					"response": []
				},
